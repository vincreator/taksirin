# Telegram Bot Token - dapatkan dari @BotFather di Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
OWNER_TELEGRAM_ID=123456789

# Pilih provider AI: gemini atau groq
AI_PROVIDER=gemini

# Google Gemini API Key - dapatkan GRATIS dari https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# (Opsional) Model Gemini yang digunakan
GEMINI_MODEL=gemini-2.0-flash-lite

# Groq API Key - dapatkan dari console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# (Opsional) Model Groq yang digunakan
GROQ_MODEL=llama-3.1-8b-instant
