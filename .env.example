# Telegram Bot Token - dapatkan dari @BotFather di Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Google Gemini API Key - dapatkan GRATIS dari https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# (Opsional) Model Gemini yang digunakan, default: gemini-2.0-flash (GRATIS)
GEMINI_MODEL=gemini-2.0-flash

# (Opsional) Jumlah hasil pencarian per marketplace, default: 5
MAX_RESULTS_PER_SOURCE=5
